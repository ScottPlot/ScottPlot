<Window x:Class="ChartsTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wpf="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        WindowStartupLocation="CenterScreen"
        Title="ScottPlot 5 - 图表测试 (散点图 / 热力图 / 等高线图 / 直方图)"
        Height="700" Width="900">
    <TabControl>
        <!-- 散点图 -->
        <TabItem Header="散点图">
            <wpf:WpfPlot x:Name="ScatterPlot" />
        </TabItem>

        <!-- 热力图 / 密度图 -->
        <TabItem Header="热力图 / 密度图">
            <wpf:WpfPlot x:Name="HeatmapPlot" />
        </TabItem>

        <!-- 等高线图 -->
        <TabItem Header="等高线图">
            <wpf:WpfPlot x:Name="ContourPlot" />
        </TabItem>

        <!-- 直方图 -->
        <TabItem Header="直方图">
            <wpf:WpfPlot x:Name="HistogramPlot" />
        </TabItem>
    </TabControl>
</Window>
