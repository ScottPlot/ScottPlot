<Window x:Class="ChartsTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wpf="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        WindowStartupLocation="CenterScreen"
        Title="ScottPlot 5 - 图表测试 (散点图 / 热力图 / 等高线图 / 直方图)"
        Height="700" Width="900">
    <TabControl>
        <!-- 散点图 -->
        <TabItem Header="散点图">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
                    <TextBlock Text="X 轴类型:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox x:Name="ScatterXAxisTypeComboBox"
                              Width="140"
                              SelectedIndex="0"
                              SelectionChanged="ScatterXAxisTypeComboBox_SelectionChanged">
                        <ComboBoxItem Content="线性 (Linear)" />
                        <ComboBoxItem Content="对数 (Log)" />
                        <ComboBoxItem Content="Biex" />
                    </ComboBox>
                    <TextBlock Text="Y 轴类型:" VerticalAlignment="Center" Margin="16,0,8,0" />
                    <ComboBox x:Name="ScatterYAxisTypeComboBox"
                              Width="140"
                              SelectedIndex="0"
                              SelectionChanged="ScatterYAxisTypeComboBox_SelectionChanged">
                        <ComboBoxItem Content="线性 (Linear)" />
                        <ComboBoxItem Content="对数 (Log)" />
                        <ComboBoxItem Content="Biex" />
                    </ComboBox>
                </StackPanel>

                <wpf:WpfPlot x:Name="ScatterPlot" />
            </DockPanel>
        </TabItem>

        <!-- 热力图 / 密度图 -->
        <TabItem Header="热力图 / 密度图">
            <wpf:WpfPlot x:Name="HeatmapPlot" />
        </TabItem>

        <!-- 等高线图 -->
        <TabItem Header="等高线图">
            <wpf:WpfPlot x:Name="ContourPlot" />
        </TabItem>

        <!-- 直方图 -->
        <TabItem Header="直方图">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
                    <TextBlock Text="X 轴类型:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox x:Name="HistogramXAxisTypeComboBox"
                              Width="140"
                              SelectedIndex="0"
                              SelectionChanged="HistogramXAxisTypeComboBox_SelectionChanged">
                        <ComboBoxItem Content="线性 (Linear)" />
                        <ComboBoxItem Content="对数 (Log)" />
                        <ComboBoxItem Content="Biex" />
                    </ComboBox>
                </StackPanel>

                <wpf:WpfPlot x:Name="HistogramPlot" />
            </DockPanel>
        </TabItem>
    </TabControl>
</Window>
